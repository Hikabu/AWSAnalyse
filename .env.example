# -----------------------------------------------------------------------------
# Copy to .env and adjust values:  cp .env.example .env
# Never commit .env (secrets).
# -----------------------------------------------------------------------------

# --- PostgreSQL (docker-compose `db` service + local DATABASE_URL host) ---
POSTGRES_USER=parser_user
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=amazon_parser

# Local tools / host scraper: use localhost. In Docker, compose sets DATABASE_URL to host `db`.
DATABASE_URL="postgresql://parser_user:strongpassword123@localhost:5432/amazon_parser"

# --- pgAdmin (docker-compose `pgadmin` service) ---
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# --- Scraper ---
# Amazon search or category URL (not hardcoded in code)
# CATEGORY_URL="https://www.amazon.com/s?k=headphones"
CATEGORY_URL="https://www.amazon.com/s?k=electronicks&crid=7JBJFDFOE35B&sprefix=electronic%2Caps%2C355&ref=nb_sb_noss_1"

# Polite delay between browser actions (ms)
REQUEST_DELAY_MIN=2000
REQUEST_DELAY_MAX=4000

# Category listing pages to scrape
MAX_PAGES=2

# Review listing pages per product
REVIEW_PAGES=2

# pino: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional stable label stored on each product; if unset, a slug is derived from CATEGORY_URL
# CATEGORY_SLUG=electronics-headphones