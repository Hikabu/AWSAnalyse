generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NEW: proper Category entity
model Category {
  id           String    @id @default(cuid())
  slug         String
  name         String
  marketplace  String    @default("amazon_us")
  browseNodeId String?
  createdAt    DateTime  @default(now())
  products     Product[]

  @@unique([slug, marketplace])
  @@index([marketplace])
}

model Product {
  id            String    @id @default(cuid())  // FIXED: was bare String @id
  asin          String
  marketplace   String    @default("amazon_us") // NEW: future-proof from day 1
  title         String
  brand         String?
  imageUrl      String?
  productUrl    String                          // renamed from url
  reviewsUrl    String?

  // CHANGED: Float -> Decimal for price, rating
  currentPrice  Decimal?  @db.Decimal(10, 2)
  currentRating Decimal?  @db.Decimal(3, 2)
  reviewCount   Int?      // updated by background job, not inline on insert

  // CHANGED: categorySlug string -> proper FK
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])

  isActive      Boolean   @default(true)
  firstSeenAt   DateTime  @default(now())
  lastScrapedAt DateTime
  updatedAt     DateTime  @updatedAt

  reviews      Review[]
  scrapeErrors ScrapeError[]

  @@unique([asin, marketplace])
  @@index([categoryId])
  @@index([lastScrapedAt])
  @@index([isActive, categoryId])
  @@index([isActive, lastScrapedAt])
}

model Review {
  id             String   @id @default(cuid())
  amazonReviewId String                         // NEW: required dedup key
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  starRating      Int                           // 1–5, was "rating"
  title           String?
  body            String?  @db.VarChar(2000)    // CAPPED: prevents runaway storage
  reviewDate      DateTime                      // NOT NULL: required for Phase 3 partitioning
  verifiedPurchase Boolean @default(false)      // was "verified"
  helpfulVotes    Int      @default(0)

  // REMOVED: author (high-cardinality, never queried)
  // REMOVED: updatedAt (write-once data)

  isActive   Boolean  @default(true)
  ingestedAt DateTime @default(now())           // was createdAt

  @@unique([amazonReviewId, productId])
  @@index([productId, reviewDate(sort: Desc)])
  @@index([productId, starRating])
  @@index([starRating, productId])
  @@index([ingestedAt])
  @@index([isActive, productId])
}

model ScrapeRun {
  id           String    @id @default(cuid())
  categorySlug String
  marketplace  String    @default("amazon_us")
  status       String    @default("running")   // running | completed | failed | partial

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  durationMs   Int?

  productsCreated     Int @default(0)
  productsUpdated     Int @default(0)
  productsSkipped     Int @default(0)
  productsDeactivated Int @default(0)
  reviewsCreated      Int @default(0)
  reviewsUpdated      Int @default(0)
  reviewsSkipped      Int @default(0)

  errorMessage String?

  @@index([categorySlug, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
}

// NEW: split error log into its own table
model ScrapeError {
  id         String   @id @default(cuid())
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])
  asin       String?
  errorType  String   // timeout | blocked | parse_failed | not_found
  message    String
  url        String?
  occurredAt DateTime @default(now())
  retryCount Int      @default(0)

  @@index([productId])
  @@index([errorType, occurredAt(sort: Desc)])
  @@index([asin])
}